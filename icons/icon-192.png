<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <rect width="192" height="192" rx="32" fill="#232f3e"/>
  <rect x="20" y="20" width="152" height="152" rx="20" fill="#FF9900" opacity="0.15"/>
  <!-- AWS風アーキテクチャ図アイコン -->
  <!-- 上段ノード -->
  <rect x="66" y="28" width="60" height="28" rx="6" fill="#FF9900"/>
  <text x="96" y="47" text-anchor="middle" font-family="monospace" font-size="11" fill="#232f3e" font-weight="bold">Route53</text>
  <!-- 矢印1 -->
  <line x1="96" y1="56" x2="96" y2="72" stroke="#FF9900" stroke-width="2.5"/>
  <polygon points="96,72 91,65 101,65" fill="#FF9900"/>
  <!-- 中段ノード -->
  <rect x="58" y="72" width="76" height="28" rx="6" fill="#FF9900"/>
  <text x="96" y="91" text-anchor="middle" font-family="monospace" font-size="11" fill="#232f3e" font-weight="bold">CloudFront</text>
  <!-- 矢印2 -->
  <line x1="96" y1="100" x2="96" y2="116" stroke="#FF9900" stroke-width="2.5"/>
  <polygon points="96,116 91,109 101,109" fill="#FF9900"/>
  <!-- 下段ノード -->
  <rect x="52" y="116" width="88" height="28" rx="6" fill="#FF9900"/>
  <text x="96" y="135" text-anchor="middle" font-family="monospace" font-size="10" fill="#232f3e" font-weight="bold">S3 Static</text>
  <!-- 矢印3 (分岐) -->
  <line x1="96" y1="144" x2="60" y2="158" stroke="#FF9900" stroke-width="2" stroke-dasharray="4,2"/>
  <line x1="96" y1="144" x2="132" y2="158" stroke="#FF9900" stroke-width="2" stroke-dasharray="4,2"/>
  <!-- 下段サービス -->
  <rect x="28" y="158" width="60" height="20" rx="4" fill="#2d3f52" stroke="#FF9900" stroke-width="1.5"/>
  <text x="58" y="172" text-anchor="middle" font-family="monospace" font-size="8" fill="#FF9900">Lambda</text>
  <rect x="104" y="158" width="60" height="20" rx="4" fill="#2d3f52" stroke="#FF9900" stroke-width="1.5"/>
  <text x="134" y="172" text-anchor="middle" font-family="monospace" font-size="8" fill="#FF9900">DynamoDB</text>
</svg>
